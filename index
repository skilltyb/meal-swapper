// ─── STATE ────────────────────────────────────────────────────────────────────
let token = null;
let curDay = 0;
let ropen = DAYS.map(d => d.meals.map(() => false));
let swaps = DAYS.map(d => d.meals.map(m => m.def));
const SK = 'ms_swaps_v2';

function saveSwaps() { try { localStorage.setItem(SK, JSON.stringify(swaps)); } catch(e){} }
function loadSwaps() {
  try {
    const s = JSON.parse(localStorage.getItem(SK));
    if (s && s.length === swaps.length) swaps = s;
  } catch(e){}
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────
function startAuth() {
  const url = 'https://accounts.google.com/o/oauth2/v2/auth?' + new URLSearchParams({
    client_id: CLIENT_ID,
    redirect_uri: REDIRECT,
    response_type: 'token',
    scope: SCOPES,
    prompt: 'consent'
  });
  window.location.href = url;
}

// ─── CALENDAR API ─────────────────────────────────────────────────────────────
async function patchEvent(eid, dayIdx, mealIdx, newName) {
  if (!eid || !token) return true; // no-op, save locally only
  const r = M[newName];
  if (!r) return false;

  const m = DAYS[dayIdx].meals[mealIdx];

  // Build clean description
  const ings = r.ing.map(([n,d]) => `• ${n}${d?' — '+d:''}`).join('\n');
  const steps = r.steps.map((s,i) => `${i+1}. ${s}`).join('\n');
  const swapList = [m.def,...m.alts].filter(a=>a!==newName).map(a=>{
    const ar=M[a]; return ar?`• ${a} (${ar.cal} cal, ${ar.pro} protein)`:`• ${a}`;
  }).join('\n');
  const desc = `📊 ${r.cal} cal · ${r.pro} protein · ${r.carb} carbs · ${r.fat} fat\n\n─── RECIPE ───\nIngredients:\n${ings}\n\nMethod:\n${steps}\n\n💡 ${r.tip||''}\n\n─── SWAPS ───\n${swapList}`;

  try {
    // Get event to find correct start time
    const ev = await fetch(
      `https://www.googleapis.com/calendar/v3/calendars/primary/events/${eid}`,
      {headers:{'Authorization':'Bearer '+token}}
    ).then(r=>r.json());

    if (ev.error) throw new Error(ev.error.message);

    // Compute this week's occurrence date
    const occDate = new Date(WEEK_START);
    occDate.setDate(occDate.getDate() + dayIdx);

    // Get the start time from original event
    const origStart = ev.start?.dateTime ? new Date(ev.start.dateTime) : null;
    let tMin, tMax;
    if (origStart) {
      tMin = new Date(occDate);
      tMin.setHours(origStart.getHours()-1, 0, 0, 0);
      tMax = new Date(occDate);
      tMax.setHours(origStart.getHours()+1, 0, 0, 0);
    } else {
      tMin = new Date(occDate); tMin.setHours(0,0,0,0);
      tMax = new Date(occDate); tMax.setHours(23,59,59,0);
    }

    // List instances to find this specific occurrence
    const instances = await fetch(
      `https://www.googleapis.com/calendar/v3/calendars/primary/events/${eid}/instances?`+
      new URLSearchParams({timeMin:tMin.toISOString(),timeMax:tMax.toISOString(),maxResults:'5'}),
      {headers:{'Authorization':'Bearer '+token}}
    ).then(r=>r.json());

    if (instances.error) throw new Error(instances.error.message);
    if (!instances.items?.length) throw new Error('No instance found for this date');

    const instance = instances.items[0];

    // Patch just this instance
    const patch = await fetch(
      `https://www.googleapis.com/calendar/v3/calendars/primary/events/${instance.id}`,
      {
        method:'PATCH',
        headers:{'Authorization':'Bearer '+token,'Content-Type':'application/json'},
        body: JSON.stringify({summary:`🥪 Lunch — ${newName}`, description:desc})
      }
    );

    if (!patch.ok) {
      const e = await patch.json();
      throw new Error(e.error?.message||'Patch failed');
    }
    return true;
  } catch(e) {
    console.error('Calendar patch error:', e);
    return false;
  }
}

// ─── SWAP HANDLER ─────────────────────────────────────────────────────────────
async function doSwap(di, mi, name) {
  if (swaps[di][mi] === name) return;
  const prev = swaps[di][mi];
  swaps[di][mi] = name;
  saveSwaps();
  render();
  showToast('Saving…', '');

  const m = DAYS[di].meals[mi];
  const ok = await patchEvent(m.eid, di, mi, name);
  if (ok) {
    showToast(`✓ ${name}`, 'ok');
  } else {
    swaps[di][mi] = prev;
    saveSwaps();
    render();
    showToast('Calendar update failed', 'err');
  }
}

// ─── RENDER ───────────────────────────────────────────────────────────────────
function getTotal(di) {
  let cal=0,pro=0,carb=0,fat=0,ok=true;
  DAYS[di].meals.forEach((_,mi)=>{
    const r=M[swaps[di][mi]];
    if(!r?.cal){ok=false;return;}
    cal+=r.cal; pro+=parseInt(r.pro); carb+=parseInt(r.carb); fat+=parseInt(r.fat);
  });
  return ok?{cal,pro:pro+'g',carb:carb+'g',fat:fat+'g'}:null;
}

function toggleRecipe(di,mi){
  ropen[di][mi]=!ropen[di][mi];
  render();
}

function showDay(idx){
  curDay=idx;
  const d=DAYS[idx];
  document.getElementById('hdrDay').textContent=d.name;
  const dt=new Date(WEEK_START);
  dt.setDate(dt.getDate()+idx);
  document.getElementById('hdrDate').textContent=dt.toLocaleDateString('en-US',{month:'short',day:'numeric'});
  document.querySelectorAll('.dpill').forEach((b,i)=>b.classList.toggle('active',i===idx));
  document.getElementById('scroll').scrollTop=0;
  render();
}

function render(){
  const d=DAYS[curDay];
  const t=getTotal(curDay);
  let h='';

  h+=`<div class="workout">${d.workout}</div>`;

  if(t){
    h+=`<div class="totals">
      <div class="tc cal"><div class="n">${t.cal}</div><div class="l">cal</div></div>
      <div class="tc pro"><div class="n">${t.pro}</div><div class="l">protein</div></div>
      <div class="tc carb"><div class="n">${t.carb}</div><div class="l">carbs</div></div>
      <div class="tc fat"><div class="n">${t.fat}</div><div class="l">fat</div></div>
    </div>`;
  }

  d.meals.forEach((m,mi)=>{
    const sel=swaps[curDay][mi];
    const r=M[sel]||{};
    const isSwapped=sel!==m.def;
    const isOpen=ropen[curDay][mi];
    const hasR=r.steps?.length>0;

    h+=`<div class="mcard${isOpen?' open':''}">
      <div class="mhead">
        <div class="mslot">${m.slot}</div>
        <div class="mtoprow">
          <div style="flex:1">
            <div class="mname">${sel}${isSwapped?'<span class="swapped-dot"></span>':''}</div>
            ${r.why?`<div class="mwhy">${r.why}</div>`:''}
            ${r.cal?`<div class="mmacros">
              <span class="mtag cal">${r.cal} cal</span>
              <span class="mtag pro">${r.pro}</span>
              <span class="mtag carb">${r.carb}</span>
              <span class="mtag fat">${r.fat}</span>
            </div>`:''}
          </div>
          ${hasR?`<button class="xbtn${isOpen?' open':''}" onclick="toggleRecipe(${curDay},${mi})">${isOpen?'▲':'▼'}</button>`:''}
        </div>
      </div>`;

    if(hasR&&isOpen){
      h+=`<div class="rpanel open"><div class="rpin">
        <div class="rlabel">Ingredients</div><ul class="ilist">`;
      r.ing.forEach(([n,d2])=>{h+=`<li><span class="in">${n}</span><span style="font-size:12px;color:var(--text3)">${d2}</span></li>`;});
      h+=`</ul><div class="rlabel">Method</div><ol class="slist">`;
      r.steps.forEach(s=>{h+=`<li>${s}</li>`;});
      h+=`</ol>`;
      if(r.tip) h+=`<div class="tip">💡 ${r.tip}</div>`;
      h+=`</div></div>`;
    }

    if(m.alts?.length){
      h+=`<div class="swapsec"><div class="swaplbl">Swap for</div><div class="swappills">`;
      [m.def,...m.alts].forEach(a=>{
        const ar=M[a];
        const safe=a.replace(/'/g,"\\'");
        h+=`<button class="spill${sel===a?' active':''}" onclick="doSwap(${curDay},${mi},'${safe}')">${a}${ar?` <span style="font-size:10px;opacity:.55;font-family:DM Mono,monospace">${ar.cal}</span>`:''}</button>`;
      });
      h+=`</div></div>`;
    }

    h+=`</div>`;
  });

  document.getElementById('content').innerHTML=h;
}

let toastT=null;
function showToast(msg,type){
  const t=document.getElementById('toast');
  t.textContent=msg; t.className='show '+(type||'');
  if(toastT) clearTimeout(toastT);
  toastT=setTimeout(()=>{t.className='';},2200);
}

function buildDayBar(){
  const bar=document.getElementById('daybar');
  bar.innerHTML='';
  DAYS.forEach((d,i)=>{
    const b=document.createElement('button');
    b.className=`dpill ${d.type}`;
    b.textContent=d.short;
    b.onclick=()=>showDay(i);
    bar.appendChild(b);
  });
}

function showApp(){
  document.getElementById('auth').style.display='none';
  document.getElementById('app').style.display='flex';
  loadSwaps();
  buildDayBar();
  // Auto-select today
  const dow=new Date().getDay(); // 0=Sun
  const idx=dow===0?6:dow-1;
  showDay(Math.min(idx,6));
}

// ─── INIT ─────────────────────────────────────────────────────────────────────
(function init(){
  // Check for OAuth token in URL hash (returned from Google)
  const hash=window.location.hash.substring(1);
  if(hash){
    const p=new URLSearchParams(hash);
    const t=p.get('access_token');
    if(t){
      token=t;
      sessionStorage.setItem('ms_token',t);
      window.history.replaceState(null,null,window.location.pathname);
      showApp();
      return;
    }
  }
  // Check session storage
  const saved=sessionStorage.getItem('ms_token');
  if(saved){ token=saved; showApp(); return; }
  // Show connect screen
  document.getElementById('auth').style.display='flex';
  document.getElementById('app').style.display='none';
})();
</script>
