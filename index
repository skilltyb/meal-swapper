<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Meal Swapper">
<title>Meal Swapper</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0f0f0f; --surface:#1a1a1a; --surface2:#222;
  --border:#2a2a2a; --border2:#333;
  --text:#f0ede8; --text2:#888; --text3:#555;
  --green:#4ade80; --green-dim:#1a3d2a;
  --amber:#fbbf24; --amber-dim:#3d2e0a;
  --blue:#60a5fa; --blue-dim:#0d1f3d;
  --red:#f87171; --radius:14px; --radius-sm:8px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow:hidden}
#app{display:flex;flex-direction:column;height:100%;height:-webkit-fill-available}

/* Auth */
#auth{position:fixed;inset:0;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px;text-align:center;gap:18px;z-index:100}
#auth h2{font-size:24px;font-weight:600}
#auth p{font-size:14px;color:var(--text2);line-height:1.6;max-width:300px}
.connect-btn{background:var(--green-dim);border:1px solid var(--green);color:var(--green);padding:16px 32px;border-radius:var(--radius);font-size:14px;font-weight:600;cursor:pointer;font-family:'DM Mono',monospace;letter-spacing:1px;text-transform:uppercase;transition:all .2s}
.connect-btn:hover{background:var(--green);color:var(--bg)}
.info-box{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;font-size:12px;color:var(--text2);line-height:1.7;max-width:320px;text-align:left}
.info-box strong{color:var(--text)}

/* Header */
#header{background:var(--bg);border-bottom:1px solid var(--border);padding:14px 18px 10px;flex-shrink:0}
#header .eyebrow{font-size:11px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:var(--text3);font-family:'DM Mono',monospace}
#header .day-name{font-size:26px;font-weight:600;letter-spacing:-.5px;margin-top:2px}
#header .date-str{font-size:12px;color:var(--text2);font-family:'DM Mono',monospace;margin-top:1px}

/* Day bar */
#daybar{display:flex;overflow-x:auto;-webkit-overflow-scrolling:touch;flex-shrink:0;border-bottom:1px solid var(--border);background:var(--bg);scrollbar-width:none}
#daybar::-webkit-scrollbar{display:none}
.dpill{flex-shrink:0;padding:10px 14px;font-size:11px;font-weight:600;color:var(--text3);border:none;background:none;cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;font-family:'DM Mono',monospace;letter-spacing:1.5px;text-transform:uppercase}
.dpill.gym.active{color:var(--blue);border-bottom-color:var(--blue)}
.dpill.golf.active{color:var(--amber);border-bottom-color:var(--amber)}
.dpill.rest.active{color:var(--green);border-bottom-color:var(--green)}

/* Scroll */
#scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:12px 14px;padding-bottom:calc(12px + env(safe-area-inset-bottom))}

/* Workout */
.workout{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 13px;margin-bottom:10px;font-size:12px;color:var(--text2);line-height:1.5;font-family:'DM Mono',monospace}

/* Totals */
.totals{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:12px}
.tc{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:9px 4px;text-align:center}
.tc .n{font-size:16px;font-weight:600;font-family:'DM Mono',monospace}
.tc .l{font-size:10px;color:var(--text3);margin-top:1px;letter-spacing:1px;text-transform:uppercase}
.tc.cal .n{color:var(--text2)} .tc.pro .n{color:var(--blue)} .tc.carb .n{color:var(--amber)} .tc.fat .n{color:var(--green)}

/* Meal card */
.mcard{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:10px;overflow:hidden}
.mcard.open{border-color:var(--border2)}
.mhead{padding:13px 14px}
.mslot{font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--text3);margin-bottom:4px;font-family:'DM Mono',monospace}
.mtoprow{display:flex;justify-content:space-between;align-items:flex-start;gap:8px}
.mname{font-size:16px;font-weight:600;line-height:1.2;flex:1}
.mwhy{font-size:12px;color:var(--text2);margin-top:4px;line-height:1.4}
.mmacros{display:flex;gap:5px;flex-wrap:wrap;margin-top:8px}
.mtag{font-size:11px;padding:2px 8px;border-radius:20px;font-family:'DM Mono',monospace;font-weight:500}
.mtag.cal{background:var(--surface2);color:var(--text2)} .mtag.pro{background:var(--blue-dim);color:var(--blue)} .mtag.carb{background:var(--amber-dim);color:var(--amber)} .mtag.fat{background:var(--green-dim);color:var(--green)}
.xbtn{flex-shrink:0;width:28px;height:28px;border-radius:50%;border:1px solid var(--border2);background:var(--surface2);color:var(--text2);font-size:11px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;margin-top:2px}
.xbtn.open{background:var(--green-dim);border-color:var(--green);color:var(--green)}
.swapped-dot{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--amber);margin-left:6px;vertical-align:middle}

/* Recipe panel */
.rpanel{display:none;border-top:1px solid var(--border)}
.rpanel.open{display:block}
.rpin{padding:13px 14px}
.rlabel{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--text3);font-family:'DM Mono',monospace;margin:12px 0 7px}
.rlabel:first-child{margin-top:0}
.ilist{list-style:none}
.ilist li{display:flex;justify-content:space-between;font-size:13px;padding:5px 0;border-bottom:1px solid var(--border);color:var(--text2)}
.ilist li:last-child{border-bottom:none}
.in{color:var(--text)}
.slist{list-style:none;counter-reset:s}
.slist li{counter-increment:s;padding:6px 0 6px 26px;border-bottom:1px solid var(--border);font-size:13px;color:var(--text2);line-height:1.5;position:relative}
.slist li:last-child{border-bottom:none}
.slist li::before{content:counter(s);position:absolute;left:0;top:7px;width:17px;height:17px;background:var(--surface2);border:1px solid var(--border2);border-radius:50%;font-size:9px;font-weight:600;color:var(--text3);display:flex;align-items:center;justify-content:center;font-family:'DM Mono',monospace}
.tip{background:var(--surface2);border-left:2px solid var(--amber);padding:8px 12px;border-radius:0 var(--radius-sm) var(--radius-sm) 0;font-size:12px;color:var(--text2);margin-top:10px;line-height:1.5}

/* Swap section */
.swapsec{border-top:1px solid var(--border);padding:11px 14px}
.swaplbl{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--text3);font-family:'DM Mono',monospace;margin-bottom:8px}
.swappills{display:flex;flex-wrap:wrap;gap:6px}
.spill{font-size:12px;padding:6px 12px;border-radius:20px;border:1px solid var(--border2);background:var(--surface2);color:var(--text2);cursor:pointer;transition:all .15s;font-weight:500}
.spill.active{background:var(--green-dim);color:var(--green);border-color:var(--green);font-weight:600}
.spill:disabled{opacity:.4;pointer-events:none}

/* Toast */
#toast{position:fixed;bottom:calc(24px + env(safe-area-inset-bottom));left:50%;transform:translateX(-50%) translateY(16px);background:var(--surface);border:1px solid var(--border2);border-radius:99px;padding:10px 18px;font-size:12px;color:var(--text);opacity:0;transition:all .3s;white-space:nowrap;z-index:999;pointer-events:none;font-family:'DM Mono',monospace;letter-spacing:.5px}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
#toast.ok{border-color:var(--green);color:var(--green)}
#toast.err{border-color:var(--red);color:var(--red)}
</style>
</head>
